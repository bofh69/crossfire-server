	@list='$(dist_adm_SCRIPTS)'; test -n "$(admdir)" || exit 0; \
	files=`for p in $$list; do echo "$$p"; done | \
	       sed -e 's,.*/,,;$(transform)'`; \
	dir='$(DESTDIR)$(admdir)'; $(am__uninstall_files_from_dir)

